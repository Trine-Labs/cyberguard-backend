# =============================================================================
# CyberGuard Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# --- Application ---
APP_NAME="CyberGuard"
APP_ENV="development"        # development | production
DEBUG=true
CORS_ORIGINS="http://localhost:3000"

# --- Neon DB (PostgreSQL) ---
# Get this from: https://console.neon.tech -> Connection String
DATABASE_URL="postgresql://neondb_owner:npg_gkVhblR0e6cG@ep-ancient-truth-aqozj6vm-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- JWT ---
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY="9f7a8b3c2d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES= 1440000
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (Fernet — local KMS stand-in) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY="lYl4H_uq8AdaoSf2o7y0RUvtE80iQjnwRrsL9LIV3i0="
# KMS_KEY_ID is a logical identifier stored in DB alongside the ciphertext
KMS_KEY_ID="cyberguard-local-v1"

# --- Microsoft 365 OAuth ---
# Create an App Registration in Azure Portal (multi-tenant)
M365_CLIENT_ID="YOUR_AZURE_APP_CLIENT_ID"
M365_CLIENT_SECRET="YOUR_AZURE_APP_CLIENT_SECRET"
M365_REDIRECT_URI="http://localhost:8000/api/v1/m365/callback"
M365_SCOPES="https://graph.microsoft.com/User.Read.All https://graph.microsoft.com/AuditLog.Read.All https://graph.microsoft.com/Policy.Read.All https://graph.microsoft.com/Directory.Read.All offline_access"

# --- Redis (Celery broker) ---
REDIS_URL="redis://localhost:6379/0"

# --- TOTP ---
TOTP_ISSUER="CyberGuard"

# --- Blocked Email Providers (comma-separated) ---
BLOCKED_EMAIL_DOMAINS="gmail.com,yahoo.com,hotmail.com,outlook.com,protonmail.com,icloud.com,live.com,msn.com,aol.com"

# --- Frontend URL (for redirects) ---
FRONTEND_URL="http://localhost:3000"
